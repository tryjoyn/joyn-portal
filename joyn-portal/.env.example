# Joyn Client Portal — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Flask ──────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=                          # 32+ random hex chars
JWT_SECRET=                          # 32+ random hex chars

# ── Database ───────────────────────────────────────────────────
DATABASE_PATH=data/portal.db

# ── Portal shared secret (used by Iris to log activity) ────────
JOYN_PORTAL_SECRET=                  # share this with Iris on Railway

# ── SendGrid ───────────────────────────────────────────────────
SENDGRID_API_KEY=
ADMIN_EMAIL=hire@tryjoyn.me

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=               # from Stripe dashboard → Webhooks

# ── CORS (comma-separated origins for production) ──────────────
CORS_ORIGINS=https://tryjoyn.me,https://www.tryjoyn.me
