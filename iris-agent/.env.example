# Iris Agent — Environment Variables
# Copy to .env for local development. Never commit .env.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                   # Your Anthropic API key

# ── Model selection ───────────────────────────────────────────────────────────
IRIS_MODEL=claude-sonnet-4-5         # or claude-opus-4-5 for production

# ── Portal connectivity ───────────────────────────────────────────────────────
JOYN_PORTAL_URL=https://your-portal.railway.app
JOYN_PORTAL_SECRET=                  # Must match JOYN_PORTAL_SECRET in portal

# ── Queue / Database ──────────────────────────────────────────────────────────
IRIS_DB_PATH=data/iris.db
IRIS_POLL_INTERVAL=30                # Seconds between queue polls

# ── Observability (optional) ──────────────────────────────────────────────────
# OTLP_ENDPOINT=https://your-grafana-cloud-otlp-endpoint
# OTLP_HEADERS=Authorization=Basic <base64-encoded-credentials>
