# Environment Variables — Copy to .env and fill in values
# DO NOT commit .env to version control

# Database
DATABASE_URL=mongodb://localhost:27017/joyn_staff

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=staff@yourdomain.com

# AI Provider (choose one)
ANTHROPIC_API_KEY=your_anthropic_key
# OPENAI_API_KEY=your_openai_key

# Staff Configuration
STAFF_NAME=YourStaffName
STAFF_MODE=autonomous  # or supervised

# Client Configuration (per-hirer)
# Set these per deployment or use database
